{
  "plugins": {
    "@release-it/bumper": {
      "in": "package.json",
      "out": ["js/constants.js"]
    }
  },
  "git": {
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "npm": {
    "publish": false
  }
}
